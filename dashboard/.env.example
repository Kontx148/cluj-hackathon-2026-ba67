# Local dev: Vite proxies /gw → gateway (see vite.config.ts).
VITE_GATEWAY_URL=http://localhost:4001
VITE_GATEWAY_2_URL=http://localhost:4002

# Production on DigitalOcean (docker compose): API calls use same-origin /gw;
# set these for the credential bar / validator panel display.
# VITE_GATEWAY_URL=/gw
# VITE_GATEWAY_PUBLIC_URL=http://YOUR_DROPLET_IP:4001
# VITE_GATEWAY_2_URL=http://YOUR_DROPLET_IP:4002
# VITE_VALIDATOR_PUBLIC_HOST=YOUR_DROPLET_IP