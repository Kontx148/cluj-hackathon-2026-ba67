VITE_GATEWAY_URL=http://localhost:4001
VITE_GATEWAY_2_URL=http://localhost:4002

# Optional. The gateway reports validator URLs with their Docker-internal
# hostnames (e.g. http://validator-1:4101). For display only, the dashboard
# rewrites those to use the gateway's public host. Set this to override the
# inferred host (otherwise the host of VITE_GATEWAY_URL is used).
# VITE_VALIDATOR_PUBLIC_HOST=165.232.67.137

# VITE_GATEWAY_URL=http://165.232.67.137:4001
# VITE_GATEWAY_2_URL=http://165.232.67.137:4002