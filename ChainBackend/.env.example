# ----------------------------------------------------------------------------
# .env.example - environment variables consumed by docker-compose.yml.
#
# Copy to .env and customise for your local setup. The defaults match what
# docker-compose.yml expects so the prototype runs out of the box.
# ----------------------------------------------------------------------------

# --- chain-backend ---
PORT=4000
NODE_ENV=development

VALIDATOR_1_URL=http://validator-1:4101
VALIDATOR_2_URL=http://validator-2:4102
CONSENSUS_THRESHOLD=2

CHAIN_STORAGE_MODE=file
CHAIN_STORAGE_PATH=/data/chain.json

# Institution + admin API keys (mock auth for the prototype).
ADMIN_API_KEY=dev-admin-key
AEP_API_KEY=dev-aep-key
BEC_API_KEY=dev-bec-key
COURT_API_KEY=dev-court-key

# --- validator-1 ---
VALIDATOR_1_PORT=4101
VALIDATOR_1_ID=validator-1
VALIDATOR_1_PRIVATE_KEY=mock-validator-1-key

# --- validator-2 ---
VALIDATOR_2_PORT=4102
VALIDATOR_2_ID=validator-2
VALIDATOR_2_PRIVATE_KEY=mock-validator-2-key
