# DigitalOcean / VPS deploy — copy to .env on the server (never commit .env)
#
#   cp .env.deploy.example .env
#   nano .env          # set GCP_PROJECT_ID, service account, strong passwords
#   docker compose up -d
#
# Server: 165.232.67.137

INGEST_API_KEY=change-me-to-a-long-random-string
GENERIC_TIMEZONE=Europe/Bucharest

SENAT_FETCH_LIMIT=5

# Vertex AI — Romanian law summaries
LLM_PROVIDER=vertex
GCP_PROJECT_ID=
GCP_REGION=europe-west4
VERTEX_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-credentials.json

# Public URLs — replace localhost with your droplet IP (or domain later)
N8N_HOST=165.232.67.137
N8N_PROTOCOL=http
WEBHOOK_URL=http://165.232.67.137:5678/

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=Civicai26

# --- Flutter app (build on your laptop, not on the server) ---
# Physical phone / release APK pointing at this server:
#   flutter build apk --release --dart-define=API_BASE=http://165.232.67.137:3001
#
# n8n workflows keep using http://feed-api:3001 inside Docker — do NOT change those to the public IP.
