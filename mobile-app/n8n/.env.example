# Copy to .env (local only — .env is gitignored, never commit it)

INGEST_API_KEY=civicai-dev-key
GENERIC_TIMEZONE=Europe/Bucharest

# Senat fetch — max bills per workflow run (default 5)
SENAT_FETCH_LIMIT=5

# Senat plain-language summaries — Google Vertex AI (Romanian)
LLM_PROVIDER=vertex
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west4
VERTEX_MODEL=gemini-2.5-flash

# Service account JSON file mounted in Docker (see docker-compose.yml)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-credentials.json

# Alternative: paste service account JSON on one line (VPS / no file mount)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Public URL for n8n webhooks (localhost for local Docker; see .env.deploy.example for VPS)
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
